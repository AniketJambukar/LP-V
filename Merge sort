#include <iostream>
#include <omp.h>
using namespace std;

void merge(int a[], int l, int m, int r)
{
    int i=l, j=m+1, k=0, temp[100];

    while(i<=m && j<=r)
        temp[k++] = (a[i] < a[j]) ? a[i++] : a[j++];

    while(i<=m) temp[k++] = a[i++];
    while(j<=r) temp[k++] = a[j++];

    for(i=l, k=0; i<=r; i++, k++)
        a[i] = temp[k];
}

void mergesort(int a[], int l, int r)
{
    if(l < r)
    {
        int m = (l + r) / 2;

        #pragma omp parallel sections
        {
            #pragma omp section
            mergesort(a, l, m);

            #pragma omp section
            mergesort(a, m+1, r);
        }

        merge(a, l, m, r);
    }
}

int main()
{
    int a[] = {12,31,25,8,32,17,40,42};
    int n = 8;

    mergesort(a, 0, n-1);

    cout << "Sorted array: ";
    for(int i=0; i<n; i++)
        cout << a[i] << " ";

    return 0;
}
